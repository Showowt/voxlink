# VoxLink Environment Variables
# Copy to .env.local for development, add to Vercel for production

# REQUIRED: Access code for app gate (4 digits)
VOXLINK_ACCESS_CODE=2468

# REQUIRED: TURN server credentials (get from metered.ca)
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential

# OPTIONAL: Metered.ca API key for dynamic TURN credentials
METERED_API_KEY=your_metered_api_key

# REQUIRED: Supabase credentials (for Proximity Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# RECOMMENDED: Upstash Redis (for production rate limiting)
# Get free tier at https://upstash.com - required for proper rate limiting in serverless
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# FUTURE: Daily.co API key (for scaling video calls)
# Currently using PeerJS (free P2P). Switch to Daily.co when ready to scale.
# See /app/lib/video-provider.ts for migration checklist
DAILY_API_KEY=your_daily_api_key
