# VoxLink Environment Variables
# Copy to .env.local for development, add to Vercel for production

# REQUIRED: Access code for app gate (4 digits)
VOXXO_ACCESS_CODE=1234

# RECOMMENDED: Secret for HMAC signing session tokens (minimum 32 chars)
# If not set, falls back to VOXXO_ACCESS_CODE (less secure)
VOXXO_TOKEN_SECRET=your_32_char_secret_key_here

# REQUIRED: Metered TURN API key (dynamic credentials via REST API)
# Get from https://www.metered.ca/dashboard
METERED_API_KEY=your_metered_api_key

# OPTIONAL: Custom Metered domain (defaults to machinemind.metered.live)
# METERED_DOMAIN=machinemind.metered.live

# REQUIRED: Supabase credentials (for Proximity Connect)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# RECOMMENDED: Upstash Redis (for production rate limiting)
# Get free tier at https://upstash.com - required for proper rate limiting in serverless
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# FUTURE (not yet integrated): Daily.co API key (for scaling video calls)
# Currently using PeerJS (free P2P). Switch to Daily.co when ready to scale.
# See /app/lib/video-provider.ts for migration checklist
DAILY_API_KEY=your_daily_api_key

# REQUIRED: Supabase Service Role Key (for webhook server-side operations)
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# STRIPE: Payment processing for Pro subscriptions
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...
# Pro subscription price ID from https://dashboard.stripe.com/products
# Price: $12.99/month - unlimited Wingman, AirPods, Proximity, Video
STRIPE_PRICE_PRO_MONTHLY=price_...

# APP URL (for Stripe redirects)
NEXT_PUBLIC_APP_URL=https://www.entrevoz.co

# OPTIONAL: Safari/Firefox speech-to-text fallback (Whisper API)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# REQUIRED: Anthropic Claude API Key (for Wingman AI suggestions)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# OPTIONAL: ElevenLabs API Key (for voice dubbing — real-time voice cloning)
# Get from https://elevenlabs.io → Profile → API Keys
ELEVEN_LABS_API_KEY=your_elevenlabs_api_key

# OPTIONAL: Cron job authentication secret (for /api/cron/monitor)
# Generate: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# OPTIONAL: Alert webhook for uptime monitoring (Discord or Slack)
ALERT_WEBHOOK_URL=https://discord.com/api/webhooks/...

# OPTIONAL: Alert email for monitoring notifications
ALERT_EMAIL=alerts@yourdomain.com

# OPTIONAL (not yet integrated): PostHog Analytics (free tier: 1M events/month)
# Get from https://app.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
